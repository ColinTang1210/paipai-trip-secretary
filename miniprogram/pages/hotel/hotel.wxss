/* pages/hotel/hotel.wxss */

/* 输入行 */
.input-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.input-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.input-value-wrapper {
  display: flex;
  align-items: center;
}

.input-value {
  font-size: 30rpx;
  color: var(--text-primary);
  margin-right: 12rpx;
}

.input-value.placeholder {
  color: var(--text-hint);
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.4;
}

/* 日期选择行 */
.date-picker-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.date-picker-item {
  flex: 1;
}

.date-label {
  font-size: 24rpx;
  color: var(--text-hint);
  display: block;
  margin-bottom: 8rpx;
}

.date-value {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.date-nights {
  width: 80rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--primary-color);
  background-color: rgba(74, 144, 217, 0.1);
  padding: 8rpx 0;
  border-radius: 8rpx;
  margin: 0 16rpx;
}

/* 关键词搜索 */
.keyword-search {
  margin-top: 20rpx;
}

.keyword-input {
  width: 100%;
  padding: 20rpx 24rpx;
  background-color: var(--bg-primary);
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 搜索按钮 */
.search-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin: 40rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.3);
}

.btn-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
}

/* 插件卡片 */
.plugin-card {
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  color: #fff;
}

.plugin-card.hotel-plugin {
  background: linear-gradient(135deg, #FF9500, #FFB340);
}

.plugin-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.plugin-logo {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background-color: rgba(255,255,255,0.3);
}

.plugin-name {
  font-size: 30rpx;
  font-weight: 600;
  display: block;
}

.plugin-desc {
  font-size: 24rpx;
  opacity: 0.8;
}

.plugin-action {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background-color: var(--bg-card);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.filter-item.active {
  color: var(--primary-color);
}

.filter-arrow {
  width: 20rpx;
  height: 20rpx;
  margin-left: 8rpx;
  opacity: 0.6;
}

.filter-icon {
  width: 28rpx;
  height: 28rpx;
  margin-left: 8rpx;
}

/* 酒店列表 */
.hotel-card {
  display: flex;
  background-color: var(--bg-card);
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.hotel-image {
  width: 220rpx;
  height: 220rpx;
  background-color: #eee;
  flex-shrink: 0;
}

.hotel-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
}

.hotel-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hotel-rating {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.rating-score {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--primary-color);
  margin-right: 10rpx;
}

.rating-text {
  font-size: 24rpx;
  color: var(--primary-color);
  margin-right: 12rpx;
}

.review-count {
  font-size: 22rpx;
  color: var(--text-hint);
}

.hotel-location {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: 12rpx;
}

.location-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
  opacity: 0.6;
}

.hotel-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: auto;
}

.hotel-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background-color: rgba(74, 144, 217, 0.1);
  color: var(--primary-color);
  border-radius: 6rpx;
  margin-right: 10rpx;
  margin-bottom: 6rpx;
}

.hotel-price-row {
  display: flex;
  align-items: baseline;
  margin-top: auto;
}

.price-label {
  font-size: 26rpx;
  color: var(--error-color);
  font-weight: 500;
}

.price-value {
  font-size: 36rpx;
  color: var(--error-color);
  font-weight: 700;
}

.price-unit {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-left: 4rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  padding: 40rpx;
  color: var(--text-hint);
  font-size: 28rpx;
}
