<!--pages/hotel/hotel.wxml-->
<view class="container">
  <view class="card">
    <view class="card-title">🏨 酒店预订</view>
    
    <view class="input-row">
      <text class="input-label">目的地</text>
      <text class="input-value">{{destination || '请选择'}}</text>
    </view>
    
    <view class="input-row">
      <text class="input-label">入住日期</text>
      <text class="input-value">{{checkInDate}}</text>
    </view>
    
    <view class="input-row">
      <text class="input-label">退房日期</text>
      <text class="input-value">{{checkOutDate}}</text>
    </view>
  </view>

  <button class="search-btn" bindtap="searchHotels">🔍 搜索酒店</button>

  <view class="hotel-list" wx:if="{{hotelList.length > 0}}">
    <view class="hotel-card" wx:for="{{hotelList}}" wx:key="id">
      <view class="hotel-info">
        <text class="hotel-name">{{item.name}}</text>
        <text class="hotel-rating">⭐ {{item.rating}}</text>
        <text class="hotel-location">📍 {{item.location}}</text>
        <text class="hotel-price">¥{{item.price}}/晚</text>
      </view>
    </view>
  </view>
</view>
