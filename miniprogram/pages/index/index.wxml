<!--pages/index/index.wxml-->
<view class="container">
  <!-- 顶部问候语 -->
  <view class="greeting-section">
    <view class="greeting-text">你好，{{userInfo.nickName || '旅行者'}}</view>
    <view class="greeting-subtitle">今天想去哪里旅行？</view>
  </view>

  <!-- 搜索框 -->
  <view class="search-box" bindtap="onSearchTap">
    <image class="search-icon" src="/assets/icons/search.png" mode="aspectFit"></image>
    <text class="search-placeholder">搜索机票、酒店、税率...</text>
  </view>

  <!-- 快捷功能入口 -->
  <view class="section">
    <view class="section-title">快捷服务</view>
    <view class="quick-actions">
      <view class="action-item" bindtap="goToFlight">
        <view class="action-icon-wrapper flight">
          <image class="action-icon" src="/assets/icons/flight-white.png" mode="aspectFit"></image>
        </view>
        <text class="action-text">机票查询</text>
      </view>
      <view class="action-item" bindtap="goToHotel">
        <view class="action-icon-wrapper hotel">
          <image class="action-icon" src="/assets/icons/hotel-white.png" mode="aspectFit"></image>
        </view>
        <text class="action-text">酒店预订</text>
      </view>
      <view class="action-item" bindtap="goToTax">
        <view class="action-icon-wrapper tax">
          <image class="action-icon" src="/assets/icons/tax-white.png" mode="aspectFit"></image>
        </view>
        <text class="action-text">税率查询</text>
      </view>
      <view class="action-item" bindtap="goToAI">
        <view class="action-icon-wrapper ai">
          <image class="action-icon" src="/assets/icons/ai-white.png" mode="aspectFit"></image>
        </view>
        <text class="action-text">AI助手</text>
      </view>
    </view>
  </view>

  <!-- 热门目的地 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">热门目的地</text>
      <text class="section-more" bindtap="onMoreDestTap">更多</text>
    </view>
    <scroll-view class="dest-scroll" scroll-x>
      <view class="dest-item" wx:for="{{hotDestinations}}" wx:key="id" bindtap="onDestTap" data-item="{{item}}">
        <image class="dest-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="dest-info">
          <text class="dest-name">{{item.name}}</text>
          <text class="dest-price">¥{{item.price}}起</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 最近搜索 -->
  <view class="section" wx:if="{{recentSearch.length > 0}}">
    <view class="section-header">
      <text class="section-title">最近搜索</text>
      <text class="section-clear" bindtap="onClearHistory">清空</text>
    </view>
    <view class="history-tags">
      <text class="history-tag" wx:for="{{recentSearch}}" wx:key="*this" bindtap="onHistoryTap" data-keyword="{{item}}">{{item}}</text>
    </view>
  </view>

  <!-- AI 推荐卡片 -->
  <view class="section">
    <view class="section-title">AI 智能推荐</view>
    <view class="ai-card" bindtap="onAICardTap">
      <view class="ai-card-header">
        <image class="ai-avatar" src="/assets/icons/ai-avatar.png" mode="aspectFit"></image>
        <view class="ai-info">
          <text class="ai-name">派派旅行助手</text>
          <text class="ai-status">在线</text>
        </view>
      </view>
      <view class="ai-suggestion">
        <text>「根据您的偏好，推荐您去日本东京，当前机票价格较低，适合出行~」</text>
      </view>
      <view class="ai-action">
        <text>点击开始对话</text>
        <text class="arrow">→</text>
      </view>
    </view>
  </view>
</view>
