/* pages/index/index.wxss */

.greeting-section {
  padding: 40rpx 0 30rpx;
}

.greeting-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.greeting-subtitle {
  font-size: 28rpx;
  color: #999;
}

/* 搜索框 */
.search-box {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 40rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.search-icon-text {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-placeholder {
  font-size: 28rpx;
  color: #999;
}

/* 区块样式 */
.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-more, .section-clear {
  font-size: 26rpx;
  color: #4A90D9;
}

/* 快捷功能 */
.quick-actions {
  display: flex;
  justify-content: space-between;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.action-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.action-icon-wrapper.flight {
  background: linear-gradient(135deg, #4A90D9, #6BA8E8);
}

.action-icon-wrapper.hotel {
  background: linear-gradient(135deg, #FF9500, #FFB340);
}

.action-icon-wrapper.tax {
  background: linear-gradient(135deg, #34C759, #5DD87D);
}

.action-icon-wrapper.ai {
  background: linear-gradient(135deg, #AF52DE, #C77DEB);
}

.action-icon-text {
  font-size: 40rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

/* 热门目的地网格 */
.dest-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.dest-item {
  width: calc(50% - 10rpx);
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dest-emoji {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.dest-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.dest-price {
  font-size: 24rpx;
  color: #FF3B30;
}

/* AI 推荐卡片 */
.ai-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  color: #fff;
}

.ai-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.ai-avatar-text {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.ai-info {
  display: flex;
  flex-direction: column;
}

.ai-name {
  font-size: 28rpx;
  font-weight: 600;
}

.ai-status {
  font-size: 22rpx;
  opacity: 0.8;
}

.ai-suggestion {
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 20rpx;
  opacity: 0.95;
}

.ai-action {
  font-size: 26rpx;
  opacity: 0.9;
}
