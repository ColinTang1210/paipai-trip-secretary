/* pages/index/index.wxss */

.greeting-section {
  padding: 40rpx 0 30rpx;
}

.greeting-text {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.greeting-subtitle {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* 搜索框 */
.search-box {
  display: flex;
  align-items: center;
  background-color: var(--bg-card);
  border-radius: 40rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 20rpx;
  opacity: 0.5;
}

.search-placeholder {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* 区块样式 */
.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-more, .section-clear {
  font-size: 26rpx;
  color: var(--primary-color);
}

/* 快捷功能 */
.quick-actions {
  display: flex;
  justify-content: space-between;
  background-color: var(--bg-card);
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.action-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.action-icon-wrapper.flight {
  background: linear-gradient(135deg, #4A90D9, #6BA8E8);
}

.action-icon-wrapper.hotel {
  background: linear-gradient(135deg, #FF9500, #FFB340);
}

.action-icon-wrapper.tax {
  background: linear-gradient(135deg, #34C759, #5DD87D);
}

.action-icon-wrapper.ai {
  background: linear-gradient(135deg, #AF52DE, #C77DEB);
}

.action-icon {
  width: 44rpx;
  height: 44rpx;
}

.action-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 热门目的地 */
.dest-scroll {
  white-space: nowrap;
  margin: 0 -30rpx;
  padding: 0 30rpx;
}

.dest-item {
  display: inline-block;
  width: 240rpx;
  margin-right: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
}

.dest-image {
  width: 240rpx;
  height: 180rpx;
  background-color: #eee;
}

.dest-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
}

.dest-name {
  display: block;
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.dest-price {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
}

/* 历史搜索 */
.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-tag {
  display: inline-block;
  padding: 12rpx 24rpx;
  background-color: var(--bg-card);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  border: 1rpx solid var(--border-color);
}

/* AI 推荐卡片 */
.ai-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  color: #fff;
}

.ai-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.ai-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background-color: rgba(255,255,255,0.3);
}

.ai-info {
  display: flex;
  flex-direction: column;
}

.ai-name {
  font-size: 28rpx;
  font-weight: 600;
}

.ai-status {
  font-size: 22rpx;
  opacity: 0.8;
}

.ai-suggestion {
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 20rpx;
  opacity: 0.95;
}

.ai-action {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 26rpx;
  opacity: 0.9;
}

.ai-action .arrow {
  font-size: 32rpx;
}
