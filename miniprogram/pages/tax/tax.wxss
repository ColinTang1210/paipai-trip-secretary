/* pages/tax/tax.wxss */
.container {
  padding: 30rpx;
  background-color: #F5F7FA;
  min-height: 100vh;
}

.card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.input-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eee;
}

.input-label {
  font-size: 28rpx;
  color: #666;
}

.input-value {
  font-size: 28rpx;
  color: #333;
}

.price-input {
  text-align: right;
  font-size: 28rpx;
  color: #333;
}

.query-btn {
  background: linear-gradient(135deg, #34C759, #5DD87D);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  margin: 30rpx 0;
}

.result-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.result-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
}

.result-row.total {
  border-top: 1rpx solid #eee;
  margin-top: 16rpx;
  padding-top: 24rpx;
}

.total-price {
  font-size: 36rpx;
  color: #FF3B30;
  font-weight: 700;
}
