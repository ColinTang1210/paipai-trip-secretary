/* pages/tax/tax.wxss */

/* 插件横幅 */
.plugin-banner {
  background: linear-gradient(135deg, #34C759, #5DD87D);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  color: #fff;
}

.plugin-content {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.plugin-logo {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background-color: rgba(255,255,255,0.3);
}

.plugin-title {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
}

.plugin-desc {
  font-size: 24rpx;
  opacity: 0.8;
}

.plugin-action {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
}

.arrow {
  font-size: 32rpx;
}

/* 输入行 */
.input-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.input-row:last-child {
  border-bottom: none;
}

.input-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
  width: 160rpx;
}

.input-value-wrapper {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: flex-end;
}

.input-value {
  font-size: 30rpx;
  color: var(--text-primary);
  margin-right: 12rpx;
}

.input-value.placeholder {
  color: var(--text-hint);
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.4;
}

.input-field-inline {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: var(--text-primary);
}

.price-input-wrapper {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: flex-end;
}

.price-input {
  text-align: right;
  width: 200rpx;
}

.currency {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-left: 12rpx;
}

/* 查询按钮 */
.query-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #34C759, #5DD87D);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin: 30rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(52, 199, 89, 0.3);
}

.btn-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
}

/* 查询结果 */
.result-section {
  margin-top: 20rpx;
}

.result-card {
  background-color: var(--bg-card);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.result-badge {
  font-size: 22rpx;
  color: var(--warning-color);
  background-color: rgba(255, 149, 0, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.result-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.result-value {
  font-size: 28rpx;
  color: var(--text-primary);
}

.result-divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: 16rpx 0;
}

.result-item.total {
  padding-top: 20rpx;
}

.result-value.total-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--error-color);
}

.result-note {
  display: flex;
  align-items: flex-start;
  margin-top: 20rpx;
  padding: 16rpx;
  background-color: var(--bg-primary);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: var(--text-hint);
  line-height: 1.5;
}

.note-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
  opacity: 0.6;
}

/* 税率详情卡片 */
.tax-detail-card {
  background-color: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.detail-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.detail-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.detail-value {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 500;
}

/* 免税额度卡片 */
.allowance-card {
  background-color: rgba(255, 149, 0, 0.08);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 149, 0, 0.2);
}

.allowance-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.allowance-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.allowance-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--warning-color);
}

.allowance-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 常见商品分类 */
.section {
  margin-top: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  display: flex;
  align-items: center;
  width: calc(50% - 8rpx);
  background-color: var(--bg-card);
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.category-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
  background-color: var(--bg-primary);
  border-radius: 10rpx;
}

.category-name {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.category-rate {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 500;
}
