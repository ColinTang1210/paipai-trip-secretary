<!--pages/tax/tax.wxml-->
<view class="container">
  <view class="card">
    <view class="card-title">💰 跨境税率查询</view>
    
    <view class="input-row" bindtap="selectCategory">
      <text class="input-label">商品类型</text>
      <text class="input-value">{{category || '请选择'}}</text>
    </view>
    
    <view class="input-row">
      <text class="input-label">商品价格</text>
      <input class="price-input" type="digit" placeholder="请输入" value="{{price}}" bindinput="onPriceInput" />
    </view>
  </view>

  <button class="query-btn" bindtap="queryTax">🔍 查询税率</button>

  <view class="result-card" wx:if="{{taxResult}}">
    <view class="result-title">税费计算结果</view>
    <view class="result-row">
      <text>商品价值</text>
      <text>{{taxResult.productValue}} 元</text>
    </view>
    <view class="result-row">
      <text>关税</text>
      <text>{{taxResult.tariff}} 元</text>
    </view>
    <view class="result-row">
      <text>增值税</text>
      <text>{{taxResult.vat}} 元</text>
    </view>
    <view class="result-row total">
      <text>应缴税费</text>
      <text class="total-price">¥{{taxResult.totalTax}}</text>
    </view>
  </view>
</view>
