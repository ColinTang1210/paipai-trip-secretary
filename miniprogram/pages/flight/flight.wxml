<!--pages/flight/flight.wxml-->
<view class="container">
  <view class="card">
    <view class="card-title">✈️ 机票查询</view>
    
    <view class="input-row" bindtap="selectCity" data-field="from">
      <text class="input-label">出发城市</text>
      <text class="input-value">{{fromCity.name || '请选择'}}</text>
    </view>
    
    <view class="input-row" bindtap="selectCity" data-field="to">
      <text class="input-label">到达城市</text>
      <text class="input-value">{{toCity.name || '请选择'}}</text>
    </view>
    
    <view class="input-row">
      <text class="input-label">出发日期</text>
      <text class="input-value">{{departDate}}</text>
    </view>
  </view>

  <button class="search-btn" bindtap="searchFlights">🔍 搜索机票</button>

  <view class="tip" wx:if="{{flightList.length === 0 && searched}}">
    <text>暂无符合条件的航班</text>
  </view>

  <view class="flight-list" wx:if="{{flightList.length > 0}}">
    <view class="flight-card" wx:for="{{flightList}}" wx:key="id">
      <view class="flight-main">
        <text class="flight-no">{{item.flightNo}}</text>
        <text class="flight-route">{{item.fromAirport}} → {{item.toAirport}}</text>
        <text class="flight-time">{{item.departTime}} - {{item.arriveTime}}</text>
        <text class="flight-price">¥{{item.price}}</text>
      </view>
    </view>
  </view>
</view>
