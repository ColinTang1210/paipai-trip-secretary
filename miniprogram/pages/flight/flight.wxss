/* pages/flight/flight.wxss */
.container {
  padding: 30rpx;
  background-color: #F5F7FA;
  min-height: 100vh;
}

.card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.input-row {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eee;
}

.input-label {
  font-size: 28rpx;
  color: #666;
}

.input-value {
  font-size: 28rpx;
  color: #333;
}

.search-btn {
  background: linear-gradient(135deg, #4A90D9, #6BA8E8);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  margin: 30rpx 0;
}

.tip {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

.flight-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.flight-main {
  display: flex;
  flex-direction: column;
}

.flight-no {
  font-size: 28rpx;
  color: #4A90D9;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.flight-route {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.flight-time {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.flight-price {
  font-size: 36rpx;
  color: #FF3B30;
  font-weight: 700;
}
